{
  "name": "instagram-video-downloader-temporal",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc --build && tsc-alias",
    "build.watch": "tsc --build --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "start": "ts-node -r tsconfig-paths/register src/workers/index.ts",
    "start.watch": "nodemon src/worker.ts",
    "workflow": "ts-node src/run-workflow.ts",
    "test": "mocha --exit --require ts-node/register --require source-map-support/register src/mocha/*.test.ts"
  },
  "nodemonConfig": {
    "execMap": {
      "ts": "ts-node"
    },
    "ext": "ts",
    "watch": [
      "src"
    ]
  },
  "dependencies": {
    "@temporalio/activity": "^1.13.0",
    "@temporalio/client": "^1.13.0",
    "@temporalio/worker": "^1.13.0",
    "@temporalio/workflow": "^1.13.0",
    "dotenv": "^17.2.3",
    "firebase": "^12.3.0",
    "firebase-admin": "^13.5.0",
    "fluent-ffmpeg": "^2.1.3",
    "formidable": "^3.5.4",
    "lodash": "^4.17.21",
    "nanoid": "3.x",
    "objection": "^3.1.5",
    "pg": "^8.16.3",
    "sharp": "^0.34.4",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@temporalio/testing": "^1.13.0",
    "@tsconfig/node18": "^18.2.4",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/formidable": "^3.4.5",
    "@types/lodash": "^4.17.20",
    "@types/mocha": "8.x",
    "@types/node": "^22.9.1",
    "@types/pg": "^8.15.5",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-deprecation": "^3.0.0",
    "mocha": "8.x",
    "nodemon": "^3.1.7",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  },
  "_moduleAliases": {
    "#types": "lib/sharedTypes/index.js",
    "src": "lib"
  }
}
