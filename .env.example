# =============================================================================
# REQUIRED ENVIRONMENT VARIABLES
# =============================================================================

# Application Environment (development, staging, production)
APP_ENV=development

# Application ID
APP_ID=your_app_id_here

# API Secret Key
API_SECRET=your_api_secret_here

# Temporal Configuration
# Address of the Temporal server (host:port)
TEMPORAL_ADDRESS=temporal.example.com:7233
TEMPORAL_NAMESPACE=default

# Database Configuration
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/database

# PostgreSQL configuration as JSON
POSTGRES_CONFIG={"host":"localhost","port":"5432","user":"temporal","password":"temporal","database":"temporal"}

# Firebase Admin Service Account Configuration (JSON string)
FIREBASE_ADMIN_SA_CONFIG_PREPROD={"type":"service_account","project_id":"your-project","private_key_id":"key_id","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com","client_id":"client_id","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk%40your-project.iam.gserviceaccount.com","universe_domain":"googleapis.com"}

# =============================================================================
# OPTIONAL ENVIRONMENT VARIABLES
# =============================================================================

# Instagram Configuration
INSTAGRAM_APP_NAME=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN_ARRAY=[]

# Allowed Sender ID
ALLOWED_SENDER_ID=

# Instagram ID
IG_ID=

# Firebase Configurations
FIREBASE_CONFIG={"apiKey":"","authDomain":"","projectId":"","storageBucket":"","messagingSenderId":"","appId":""}
FIREBASE_CONFIG_PREPROD={"apiKey":"","authDomain":"","projectId":"","storageBucket":"","messagingSenderId":"","appId":""}
FIREBASE_CONFIG_REELS_CREATOR={"apiKey":"","authDomain":"","projectId":"","storageBucket":"","messagingSenderId":"","appId":""}

# Heroku Configuration
HEROKU_API_KEY=
HEROKU_APP_NAME=

# YouTube OAuth Configuration
YT_CLOUD_ID=
YT_SECRET_ID=
YT_REDIRECT_URL=
YT_REFRESH_TOKEN=

# Google Cloud Platform Configuration
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Backend Endpoint
MAIN_BACKEND_ENDPOINT=http://localhost:8080

# Feature Flags
ENABLE_STDERR=true
ENABLE_PROGRESS=true
ENABLE_START=true
ENABLE_DOWNLOAD_VIDEO=false
ENABLE_RUN_SCENARIO_VIDEO=false
ENABLE_PREPROCESS_VIDEO=false

# Super Admin Secret
SUPER_ADMIN_SECRET=
