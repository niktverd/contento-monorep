# Production Environment Variables for Instagram Video Downloader
# Copy this file to .env.production and set actual values before deployment

# ================================
# Database Configuration
# ================================
POSTGRES_DB=temporal
POSTGRES_USER=temporal
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_HOST_AUTH_METHOD=md5

# Database connection string for application
DATABASE_URL=postgresql://temporal:your_secure_postgres_password_here@postgresql:5432/temporal

# ================================
# Temporal Configuration  
# ================================
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TLS_ENABLED=false
TEMPORAL_CLI_ADDRESS=temporal:7233

# Temporal Database Settings
DB=postgres12
DB_PORT=5432
POSTGRES_USER=temporal
POSTGRES_PWD=your_secure_postgres_password_here
POSTGRES_SEEDS=postgresql
SKIP_SCHEMA_SETUP=false
SKIP_DB_CREATE=false

# ================================
# Application Configuration
# ================================
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# API Configuration
API_PORT=8080
API_HOST=0.0.0.0

# ================================
# Worker Configuration
# ================================
# Downloading Worker Settings
DOWNLOADING_WORKER_CONCURRENCY=15
DOWNLOADING_WORKER_MAX_WORKFLOWS=25
DOWNLOADING_WORKER_TASK_QUEUE=video-downloading

# Processing Worker Settings  
PROCESSING_WORKER_CONCURRENCY=5
PROCESSING_WORKER_MAX_WORKFLOWS=10
PROCESSING_WORKER_TASK_QUEUE=video-processing

# ================================
# Activity Timeouts (Production Optimized)
# ================================
# Download Activities (5-7 minutes for network I/O)
DOWNLOAD_VIDEO_START_TO_CLOSE_TIMEOUT=PT7M
DOWNLOAD_VIDEO_SCHEDULE_TO_CLOSE_TIMEOUT=PT7M30S
GET_ACCOUNTS_START_TO_CLOSE_TIMEOUT=PT5M
GET_ACCOUNTS_SCHEDULE_TO_CLOSE_TIMEOUT=PT5M30S

# Process Activities (15-18 minutes for CPU intensive)
PROCESS_VIDEO_START_TO_CLOSE_TIMEOUT=PT18M
PROCESS_VIDEO_SCHEDULE_TO_CLOSE_TIMEOUT=PT20M

# Instagram Activities (8-10 minutes for API intensive)
INSTAGRAM_ACTIVITY_START_TO_CLOSE_TIMEOUT=PT10M
INSTAGRAM_ACTIVITY_SCHEDULE_TO_CLOSE_TIMEOUT=PT12M

# ================================
# Retry Policies
# ================================
# Download retries (network issues)
DOWNLOAD_VIDEO_MAXIMUM_ATTEMPTS=3
DOWNLOAD_VIDEO_INITIAL_INTERVAL=PT10S
DOWNLOAD_VIDEO_BACKOFF_COEFFICIENT=2.0
DOWNLOAD_VIDEO_MAXIMUM_INTERVAL=PT2M

# Process retries (heavy operations)
PROCESS_VIDEO_MAXIMUM_ATTEMPTS=2
PROCESS_VIDEO_INITIAL_INTERVAL=PT30S
PROCESS_VIDEO_BACKOFF_COEFFICIENT=1.5
PROCESS_VIDEO_MAXIMUM_INTERVAL=PT5M

# Instagram retries (API rate limits)
INSTAGRAM_ACTIVITY_MAXIMUM_ATTEMPTS=5
INSTAGRAM_ACTIVITY_INITIAL_INTERVAL=PT5S
INSTAGRAM_ACTIVITY_BACKOFF_COEFFICIENT=2.0
INSTAGRAM_ACTIVITY_MAXIMUM_INTERVAL=PT1M

# ================================
# Resource Limits
# ================================
# Download Worker Resources
DOWNLOAD_WORKER_MEMORY_LIMIT=512M
DOWNLOAD_WORKER_CONCURRENCY_LIMIT=5

# Process Worker Resources  
PROCESS_WORKER_MEMORY_LIMIT=2G
PROCESS_WORKER_CONCURRENCY_LIMIT=2

# Instagram Worker Resources
INSTAGRAM_WORKER_MEMORY_LIMIT=256M
INSTAGRAM_WORKER_CONCURRENCY_LIMIT=10

# ================================
# Security & Authentication
# ================================
# Basic Auth for Temporal UI (will be set by deployment script)
TEMPORAL_UI_AUTH_USER=admin
TEMPORAL_UI_AUTH_PASSWORD=your_secure_ui_password_here

# SSL/TLS Configuration
SSL_CERT_PATH=/etc/ssl/certs/temporal.crt
SSL_KEY_PATH=/etc/ssl/private/temporal.key
SSL_CA_PATH=/etc/ssl/certs/ca.crt

# ================================
# Monitoring & Observability
# ================================
# Health Check Configuration
HEALTH_CHECK_PORT=8080
HEALTH_CHECK_PATH=/health

# Metrics Configuration
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Logging Configuration
LOG_FORMAT=json
LOG_TIMESTAMP=true
LOG_COLORS=false

# ================================
# Backup Configuration
# ================================
BACKUP_DIR=/var/backups/postgres
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE=0 2 * * *

# ================================
# External Services (if needed)
# ================================
# Instagram API Configuration
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

# Firebase Configuration (if used)
FIREBASE_CONFIG=your_firebase_config_json

# Cloud Storage (if used)
CLOUD_STORAGE_BUCKET=your_storage_bucket
CLOUD_STORAGE_PROJECT_ID=your_project_id 

