# ====================================
# Temporal Production Configuration
# ====================================

# Basic Temporal Connection
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=video-processing

# ====================================
# Worker Configuration
# ====================================

# Worker Capacity Settings
TEMPORAL_WORKER_MAX_CONCURRENT_ACTIVITIES=10
TEMPORAL_WORKER_MAX_CONCURRENT_WORKFLOWS=100
TEMPORAL_WORKER_STICKY_QUEUE_SCHEDULE_TO_START_TIMEOUT=10s

# Worker Lifecycle
TEMPORAL_WORKER_SHUTDOWN_TIMEOUT=30s
TEMPORAL_WORKER_GRACEFUL_SHUTDOWN_TIMEOUT=10s

# ====================================
# Workflow Timeouts (Production)
# ====================================

# Total workflow execution limits
TEMPORAL_WORKFLOW_EXECUTION_TIMEOUT=30m
TEMPORAL_WORKFLOW_RUN_TIMEOUT=25m
TEMPORAL_WORKFLOW_TASK_TIMEOUT=1m

# ====================================
# Activity Timeouts (Production)
# ====================================

# Download Activity (Network I/O intensive)
TEMPORAL_DOWNLOAD_START_TO_CLOSE_TIMEOUT=5m
TEMPORAL_DOWNLOAD_SCHEDULE_TO_START_TIMEOUT=2m
TEMPORAL_DOWNLOAD_SCHEDULE_TO_CLOSE_TIMEOUT=7m
TEMPORAL_DOWNLOAD_HEARTBEAT_TIMEOUT=30s

# Process Activity (CPU intensive, long running)
TEMPORAL_PROCESS_START_TO_CLOSE_TIMEOUT=15m
TEMPORAL_PROCESS_SCHEDULE_TO_START_TIMEOUT=3m
TEMPORAL_PROCESS_SCHEDULE_TO_CLOSE_TIMEOUT=18m
TEMPORAL_PROCESS_HEARTBEAT_TIMEOUT=60s

# Instagram Activities (API intensive)
TEMPORAL_INSTAGRAM_START_TO_CLOSE_TIMEOUT=8m
TEMPORAL_INSTAGRAM_SCHEDULE_TO_START_TIMEOUT=2m
TEMPORAL_INSTAGRAM_SCHEDULE_TO_CLOSE_TIMEOUT=10m
TEMPORAL_INSTAGRAM_HEARTBEAT_TIMEOUT=30s

# ====================================
# Retry Policies
# ====================================

# Download Activity Retries (Network issues)
TEMPORAL_DOWNLOAD_RETRY_MAXIMUM_ATTEMPTS=3
TEMPORAL_DOWNLOAD_RETRY_INITIAL_INTERVAL=1s
TEMPORAL_DOWNLOAD_RETRY_MAXIMUM_INTERVAL=30s
TEMPORAL_DOWNLOAD_RETRY_BACKOFF_COEFFICIENT=2.0
TEMPORAL_DOWNLOAD_RETRY_NON_RETRYABLE_ERROR_TYPES=InvalidArgument,NotFound

# Process Activity Retries (Rare retries for processing)
TEMPORAL_PROCESS_RETRY_MAXIMUM_ATTEMPTS=2
TEMPORAL_PROCESS_RETRY_INITIAL_INTERVAL=5s
TEMPORAL_PROCESS_RETRY_MAXIMUM_INTERVAL=2m
TEMPORAL_PROCESS_RETRY_BACKOFF_COEFFICIENT=2.0
TEMPORAL_PROCESS_RETRY_NON_RETRYABLE_ERROR_TYPES=InvalidArgument,DataLoss

# Instagram Activity Retries (API rate limits)
TEMPORAL_INSTAGRAM_RETRY_MAXIMUM_ATTEMPTS=5
TEMPORAL_INSTAGRAM_RETRY_INITIAL_INTERVAL=2s
TEMPORAL_INSTAGRAM_RETRY_MAXIMUM_INTERVAL=1m
TEMPORAL_INSTAGRAM_RETRY_BACKOFF_COEFFICIENT=1.5
TEMPORAL_INSTAGRAM_RETRY_NON_RETRYABLE_ERROR_TYPES=InvalidArgument,PermissionDenied

# ====================================
# Monitoring and Observability
# ====================================

# Logging Configuration
TEMPORAL_LOG_LEVEL=info
TEMPORAL_LOG_FORMAT=json
TEMPORAL_LOG_TIMESTAMPS=true

# Metrics and Health Checks
TEMPORAL_METRICS_ENABLED=true
TEMPORAL_METRICS_PORT=9090
TEMPORAL_HEALTH_CHECK_PORT=8080
TEMPORAL_HEALTH_CHECK_INTERVAL=30s

# Prometheus Metrics (if using)
TEMPORAL_PROMETHEUS_ENDPOINT=/metrics
TEMPORAL_PROMETHEUS_NAMESPACE=temporal_worker

# ====================================
# Feature Flags
# ====================================

# Worker Process Control
TEMPORAL_ENABLE_WORKER=true
TEMPORAL_ENABLE_API_ENDPOINTS=true

# Migration Control
TEMPORAL_ENABLE_CRON_MIGRATION=false
TEMPORAL_PUBSUB_FALLBACK_ENABLED=true

# Testing and Development
TEMPORAL_E2E_TESTS=false
TEMPORAL_DEBUG_MODE=false

# ====================================
# Production Security
# ====================================

# TLS Configuration (for production Temporal Server)
TEMPORAL_TLS_ENABLED=false
TEMPORAL_TLS_CERT_PATH=/path/to/cert.pem
TEMPORAL_TLS_KEY_PATH=/path/to/key.pem
TEMPORAL_TLS_CA_PATH=/path/to/ca.pem

# Authentication (if using Temporal Cloud)
TEMPORAL_CLOUD_NAMESPACE=your-namespace.account-id
TEMPORAL_CLOUD_API_KEY=your-api-key
TEMPORAL_CLOUD_CERT_PATH=/path/to/temporal-cloud.pem
TEMPORAL_CLOUD_KEY_PATH=/path/to/temporal-cloud.key

# ====================================
# Resource Limits
# ====================================

# Memory and CPU limits for activities
TEMPORAL_DOWNLOAD_MEMORY_LIMIT=512MB
TEMPORAL_PROCESS_MEMORY_LIMIT=2GB
TEMPORAL_INSTAGRAM_MEMORY_LIMIT=256MB

# Concurrent execution limits per activity type
TEMPORAL_DOWNLOAD_CONCURRENT_LIMIT=5
TEMPORAL_PROCESS_CONCURRENT_LIMIT=2
TEMPORAL_INSTAGRAM_CONCURRENT_LIMIT=10

# ====================================
# Usage Instructions
# ====================================

# 1. Copy this file to .env.temporal in your project root
# 2. Adjust values based on your infrastructure capacity
# 3. For production, use external secret management
# 4. Monitor metrics and adjust timeouts based on performance
# 5. Test configuration changes in staging environment first

# Example production setup:
# - Use Temporal Cloud or self-hosted cluster
# - Set appropriate resource limits
# - Enable TLS and authentication
# - Configure monitoring and alerting
# - Set up log aggregation 