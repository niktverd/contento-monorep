# Temporal Configuration
# Copy these variables to your .env file and adjust values as needed

# Temporal Server Connection
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=video-processing-queue

# Temporal Client Options (milliseconds)
TEMPORAL_CLIENT_TIMEOUT=30000
TEMPORAL_CONNECTION_TIMEOUT=10000

# Temporal Worker Configuration
TEMPORAL_WORKER_MAX_CONCURRENT_ACTIVITIES=10
TEMPORAL_WORKER_MAX_CONCURRENT_WORKFLOWS=50

# Temporal Workflow Timeouts (in seconds)
TEMPORAL_WORKFLOW_EXECUTION_TIMEOUT=1800
TEMPORAL_WORKFLOW_RUN_TIMEOUT=1800  
TEMPORAL_WORKFLOW_TASK_TIMEOUT=10

# Temporal Activity Timeouts (in seconds)
TEMPORAL_ACTIVITY_START_TO_CLOSE_TIMEOUT=300
TEMPORAL_ACTIVITY_SCHEDULE_TO_START_TIMEOUT=60
TEMPORAL_ACTIVITY_SCHEDULE_TO_CLOSE_TIMEOUT=360
TEMPORAL_ACTIVITY_HEARTBEAT_TIMEOUT=30

# Production Configuration
# For production, change TEMPORAL_ADDRESS to your Temporal Cloud endpoint
# TEMPORAL_ADDRESS=your-namespace.account.tmprl.cloud:7233
# Add TLS and authentication configuration for production 